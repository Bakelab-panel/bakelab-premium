---
import ProjectDetail from '@components/ProjectDetail.astro';
import PremiumLayout from '@layouts/PremiumLayout.astro';
import { getCopy, projects } from '@data/projects';
import { siteEn } from '@data/site.en';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const copy = getCopy(project, 'en');
---

<PremiumLayout
  site={siteEn}
  title={`${copy.title} â€” !bakelab`}
  description={copy.description}
  image={project.cover ?? siteEn.seo.image}
  alternateHref={`/pt/projetos/${project.slug}`}
>
  <ProjectDetail site={siteEn} project={project} />
</PremiumLayout>
