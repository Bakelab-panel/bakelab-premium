---
import { assets } from '@data/assets';
import type { SiteCopy } from '@data/types';

type Props = {
  site: SiteCopy;
};

const { site } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-platinum/10 bg-obsidian">
  <div class="container-px grid gap-8 py-10 lg:grid-cols-[1fr_auto]">
    <div>
      {assets.icon && <img src={assets.icon} alt="" class="mb-5 h-10 w-auto" width="44" height="44" loading="lazy" />}
      <p class="font-display text-2xl font-black text-platinum">!bakelab</p>
      <p class="mt-2 font-mono text-xs uppercase tracking-[0.22em] text-ash">{site.footer.line}</p>
      <p class="mt-3 text-sm text-mist">{site.footer.location}</p>
    </div>

    <div class="flex flex-wrap gap-3 lg:justify-end">
      {site.contact.links.map((link) => (
        <a
          href={link.href}
          class="border border-platinum/10 px-3 py-2 font-mono text-[0.68rem] uppercase tracking-[0.2em] text-mist transition hover:border-ember hover:text-ember"
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <p class="font-mono text-[0.68rem] uppercase tracking-[0.2em] text-ash lg:col-span-2">
      Â© {year} !bakelab / Eder Azevedo
    </p>
  </div>
</footer>
